# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Paystack ──────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ── AI Providers (all optional — missing keys are skipped, not fatal) ──
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=

# Order providers are tried in, comma-separated, first is primary
AI_PROVIDER_PRIORITY=anthropic,openai,gemini,groq,together,openrouter,cohere,deepseek

# ── Web search (Tavily) — powers the composer's Search toggle ─────────
# Missing key = toggle is a no-op, chat still works normally.
TAVILY_API_KEY=
